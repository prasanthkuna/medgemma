# Pramana AI - Environment Template
# Duplicate this file as .env and fill in the values

# --- App Mode ---
PRAMANA_DEBUG=True

# --- Backend API ---
PRAMANA_API_HOST=0.0.0.0
PRAMANA_API_PORT=8000

# --- Medical Clinical AI & RAG Configuration ---
